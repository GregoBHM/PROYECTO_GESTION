# ── Django ──────────────────────────────────────────────────────────────────
SECRET_KEY=django-insecure-cambia-esta-clave-en-produccion-por-favor
DJANGO_SETTINGS_MODULE=core.settings.development

# ── Base de Datos PostgreSQL ─────────────────────────────────────────────────
DB_NAME=gestiocambios_db
DB_USER=gestiocambios
DB_PASSWORD=gestiocambios_pass
DB_HOST=db
DB_PORT=5432

# ── CORS (dominio del frontend) ──────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:5173

# ── Hosts permitidos en producción ───────────────────────────────────────────
ALLOWED_HOSTS=localhost,127.0.0.1

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=cambia-este-secreto-jwt-tambien

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
VITE_API_URL=/api
